# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Only needed if the deployed app is served from a different public
# domain than the one issuing requests (rare for this single-server setup).
FRONTEND_URL=

# ── MongoDB ──────────────────────────────────────────────────────
# REQUIRED. Get a free cluster at https://www.mongodb.com/cloud/atlas/register
# (Atlas → Build a Database → Free/M0 → Connect → "Drivers" → copy the string,
# then replace <username>/<password>/<dbname> below). A local mongod URI
# (mongodb://localhost:27017/shah-premium-foods) works too if you have one.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>

# ── JWT ──────────────────────────────────────────────────────────
# REQUIRED. Any long random string works — e.g. generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET_ACCESS=replace_with_a_long_random_string
JWT_SECRET_REFRESH=replace_with_a_different_long_random_string
# Security audit: access tokens are now genuinely short-lived (paired with
# refresh token rotation — see generateRefreshToken.js / sessionManager.js).
# Leave this at 15m unless you have a specific reason to change it.
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# ── Cloudinary (image uploads — products, avatars, banners) ────
# REQUIRED for image uploads. Free account: https://cloudinary.com/users/register/free
# Dashboard → copy Cloud Name / API Key / API Secret.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret

# ── Resend (transactional email — OTPs, password reset) ─────────
# Free account: https://resend.com/signup → API Keys → create one.
# Note: on Resend's free/sandbox tier you can only send TO the email address
# you signed up with until you verify a sending domain — that's expected,
# not a bug. Email delivery failing never blocks registration or login in
# this app; the OTP screen also has a "Resend" button and a "log in now,
# verify later" link for exactly this situation.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Stripe (optional — only needed for online card payments) ────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Frontend-exposed config (Next.js) ───────────────────────────
# Left empty = same-origin. Only set this if the API is hosted elsewhere.
NEXT_PUBLIC_API_URL=

# Fix 9: your real deployed domain (no trailing slash), e.g. https://shahpremiumfoods.com
# Used to build absolute URLs in /sitemap.xml — sitemaps require full URLs,
# search engines will reject relative ones. Falls back to a placeholder if unset.
# Security audit: ALSO used by src/lib/security.js to verify the Origin/
# Referer header on every state-changing API request (CSRF protection) —
# set this correctly in production, or that check silently no-ops (fails
# open, logged nowhere) rather than false-positive-blocking every request
# in a misconfigured deployment. See security.js's own comment for why.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CURRENCY_LOCALE=en-BD
